import numpy as np
import matplotlib.pyplot as plt
import tensorflow as tf
from sklearn.datasets import make_circles
from sklearn.model_selection import train_test_split

# Create sample data
features, labels = make_circles(
    n_samples=1000,
    noise=0.03,
    random_state=42
)

# Split into training and testing parts
X_train, X_test, y_train, y_test = train_test_split(
    features,
    labels,
    test_size=0.2,
    random_state=42
)

# Build a simple neural network
network = tf.keras.Sequential()
network.add(tf.keras.layers.Dense(12, activation="relu", input_shape=(2,)))
network.add(tf.keras.layers.Dense(12, activation="relu"))
network.add(tf.keras.layers.Dense(1, activation="sigmoid"))

# Prepare the model for training
network.compile(
    optimizer="adam",
    loss="binary_crossentropy",
    metrics=["accuracy"]
)

# Train the model
network.fit(X_train, y_train, epochs=30, verbose=0)

# Check performance on test data
test_loss, test_accuracy = network.evaluate(X_test, y_test, verbose=0)
print("Test accuracy:", round(test_accuracy, 3))

# Make a grid to draw the decision boundary
x_min, x_max = features[:, 0].min() - 0.1, features[:, 0].max() + 0.1
y_min, y_max = features[:, 1].min() - 0.1, features[:, 1].max() + 0.1

x_values = np.linspace(x_min, x_max, 200)
y_values = np.linspace(y_min, y_max, 200)
grid_x, grid_y = np.meshgrid(x_values, y_values)

all_points = np.column_stack((grid_x.ravel(), grid_y.ravel()))
predictions = network.predict(all_points, verbose=0)
predictions = predictions.reshape(grid_x.shape)

# Plot results
plt.figure(figsize=(6, 5))
plt.contourf(grid_x, grid_y, predictions > 0.5, alpha=0.6, cmap=plt.cm.coolwarm)
plt.scatter(X_test[:, 0], X_test[:, 1], c=y_test, edgecolors="black", cmap=plt.cm.coolwarm)
plt.title("Neural Network Decision Boundary")
plt.xlabel("Feature 1")
plt.ylabel("Feature 2")
plt.show()
